# PayPay OPA API credentials — get these from the PayPay for Developers portal.
# Copy this file to .env (which is gitignored) and fill in real values.

# The full API key (sometimes labelled "Key ID" — e.g. a_xxxxxxxx_yyyy)
PAYPAY_API_KEY=your_sandbox_api_key_here

# The API secret paired with the key
PAYPAY_API_SECRET=your_sandbox_api_secret_here

# Numeric merchant ID (~18 digits)
PAYPAY_MERCHANT_ID=your_sandbox_merchant_id_here

# Mini App UserAuth Client ID — only needed for the UserAuth flow,
# not for the QR code payment endpoints in this server.
PAYPAY_USER_AUTH_CLIENT_ID=

# false = sandbox (api-sandbox.paypay.ne.jp), true = production
PAYPAY_PRODUCTION_MODE=false

# Where PayPay redirects the user after they approve the payment.
# Inside the Mini App runtime this should be a `paypay://` deeplink back
# to your mini app; for browser demos point at a reachable URL.
REDIRECT_URL=https://example.com/paypay/redirect

PORT=3000
